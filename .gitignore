# ============================================================
# Python 缓存与编译产物
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
.eggs/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# ============================================================
# Jupyter / IPython
# ============================================================
.ipynb_checkpoints/
*.ipynb

# ============================================================
# 数据集（体积大，不入库）
# ============================================================
/datasets/
deploy/datasets/

# ============================================================
# 模型权重文件（体积大，不入库）
# ============================================================
*.onnx
*.engine
*.pt
*.pth
*.joblib
*.tflite
*.trt
*.wts

# ============================================================
# 预训练权重
# ============================================================
**/pretrained/

# ============================================================
# 训练结果 / 运行产物
# ============================================================
/results/
**/runs/
deploy/results/
deploy/reports/

# ============================================================
# 日志文件（保留重要的过程记录日志）
# ============================================================
# 通用日志忽略规则，但保留 power.log
*.log
!**/power.log                  # 功耗测量过程数据，保留入库

# ============================================================
# 生成的图片（演示截图、训练曲线等，可重新生成）
# ============================================================
*.jpg
reports/figures/

# ============================================================
# 归档目录（旧代码备份，不入库）
# ============================================================
/archive/

# ============================================================
# 大型 JSON 结果文件
# ============================================================
deploy/results/*.json

# ============================================================
# IDE / 编辑器
# ============================================================
.vscode/
.idea/
*.swp
*.swo
*~
.qoder/

# ============================================================
# 操作系统
# ============================================================
.DS_Store
Thumbs.db
Desktop.ini

# ============================================================
# 环境 / 杂项
# ============================================================
.env
*.bak
*.tmp
plan.md
deploy/plan.md
